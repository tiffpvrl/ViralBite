YOUTUBE_API_KEY=your_youtube_api_key_here
GOOGLE_CLOUD_PROJECT=your_gcp_project_id
# NLP summary / creator brief (structured output)
VERTEXAI_CREATOR_MODEL=gemini-2.5-pro
# Chat assistant (faster, cheaper per turn)
VERTEXAI_CHAT_MODEL=gemini-2.5-flash
# Optional legacy: if set, used only when CREATOR/CHAT vars above are unset
# VERTEXAI_MODEL=gemini-2.5-flash
VERTEXAI_THEME_MODEL=gemini-2.5-flash
VIRALBITE_CACHE_TTL_SECONDS=600
VIRALBITE_COMMENT_WORKERS=6
VIRALBITE_MAX_COMMENT_VIDEOS=12
VIRALBITE_ENABLE_TRANSCRIPTS=1
VIRALBITE_TRANSCRIPT_WORKERS=4
VIRALBITE_MAX_TRANSCRIPT_VIDEOS=8
